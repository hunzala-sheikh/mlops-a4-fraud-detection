{
  "title": "Fraud — System Health",
  "uid": "fraud-system",
  "tags": ["mlops", "fraud", "system"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "type": "timeseries",
      "title": "API request rate (req/s)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (status) (rate(fraud_api_requests_total[1m]))", "legendFormat": "{{status}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency (p50 / p95 / p99)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(fraud_api_latency_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(fraud_api_latency_seconds_bucket[5m])))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(fraud_api_latency_seconds_bucket[5m])))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "stat",
      "title": "Error rate %",
      "gridPos": {"x": 0, "y": 7, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (sum(rate(fraud_api_requests_total{status!=\"ok\"}[5m])) or vector(0)) / clamp_min(sum(rate(fraud_api_requests_total[5m])), 0.0001)"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"value": null, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 5, "color": "red"}]}}}
    },
    {
      "type": "timeseries",
      "title": "CPU usage (cores) - inference Pod",
      "gridPos": {"x": 8, "y": 7, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(process_cpu_seconds_total{job=\"fraud-inference-api\"}[5m])", "legendFormat": "{{instance}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory usage (MB) - inference Pod",
      "gridPos": {"x": 16, "y": 7, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "process_resident_memory_bytes{job=\"fraud-inference-api\"} / 1024 / 1024", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "decmbytes"}}
    },
    {
      "type": "stat",
      "title": "Throughput (req/s, 1m)",
      "gridPos": {"x": 0, "y": 13, "w": 8, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(fraud_api_requests_total[1m]))"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "stat",
      "title": "Total requests (24h)",
      "gridPos": {"x": 8, "y": 13, "w": 8, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(fraud_api_requests_total[24h]))"}]
    },
    {
      "type": "stat",
      "title": "Inference Pod up?",
      "gridPos": {"x": 16, "y": 13, "w": 8, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(up{job=\"fraud-inference-api\"})"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}}
    }
  ]
}
