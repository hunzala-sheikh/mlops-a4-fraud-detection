{
  "title": "Fraud — Model Performance",
  "uid": "fraud-model",
  "tags": ["mlops", "fraud", "model"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "type": "timeseries",
      "title": "Fraud-flag rate (recall proxy)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "rate(fraud_api_predictions_fraud_total[10m]) / (rate(fraud_api_predictions_fraud_total[10m]) + rate(fraud_api_predictions_legit_total[10m]))",
        "legendFormat": "fraud_rate"
      }]
    },
    {
      "type": "timeseries",
      "title": "Predicted probability distribution (rolling avg)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "rate(fraud_api_predicted_probability_sum[5m]) / rate(fraud_api_predicted_probability_count[5m])",
        "legendFormat": "mean_proba"
      }]
    },
    {
      "type": "timeseries",
      "title": "False Positive Rate (FP / (FP+TN))",
      "gridPos": {"x": 0, "y": 7, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "rate(fraud_api_label_fp_total[10m]) / (rate(fraud_api_label_fp_total[10m]) + rate(fraud_api_label_tn_total[10m]))",
        "legendFormat": "fpr"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.05, "color": "yellow"},
              {"value": 0.10, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Precision–Recall trade-off",
      "gridPos": {"x": 12, "y": 7, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(fraud_api_label_tp_total[10m]) / (rate(fraud_api_label_tp_total[10m]) + rate(fraud_api_label_fp_total[10m]))",
          "legendFormat": "precision"
        },
        {
          "expr": "rate(fraud_api_label_tp_total[10m]) / (rate(fraud_api_label_tp_total[10m]) + rate(fraud_api_label_fn_total[10m]))",
          "legendFormat": "recall"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Predictions in last 24h - Fraud",
      "gridPos": {"x": 0, "y": 14, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "increase(fraud_api_predictions_fraud_total[24h])"}]
    },
    {
      "type": "stat",
      "title": "Predictions in last 24h - Legit",
      "gridPos": {"x": 6, "y": 14, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "increase(fraud_api_predictions_legit_total[24h])"}]
    },
    {
      "type": "timeseries",
      "title": "Prediction confidence distribution (histogram buckets)",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "rate(fraud_api_predicted_probability_bucket[5m])",
        "legendFormat": "<= {{le}}"
      }]
    }
  ]
}
