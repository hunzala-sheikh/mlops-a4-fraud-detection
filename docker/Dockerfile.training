# Training pipeline image - used by KFP components.
FROM python:3.11-slim

ENV OMP_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /workspace

COPY requirements-train.txt .
RUN pip install --no-cache-dir -r requirements-train.txt

COPY src/ ./src/
COPY data/generate_fraud_dataset.py ./data/

# Default entry point: compile pipelines (used in CI for sanity-check)
CMD ["python", "-m", "src.compile_all"]
